MAP Node = {
    INT value = 0,
    REF[Node] next = NUL
}

MAP List = {
    REF[Node] head = NUL,
    REF[Node] tail = NUL,
    INT count = 0
}

FN append(REF[List] list, REF[Node] node, INT value) -> NUL = (
    *node.value = value
    *node.next = NUL

    if(list.head == NUL)(
        *list.head = node
        *list.tail = node
    ) else (
        tail = list.tail
        *tail.next = node
        *list.tail = node
    )

    *list.count += 1
)

FN printList(REF[List] list) -> NUL = (
    current = list.head

    loop(current != NUL)(
        log(current.value)
        current = current.next
    )
)

FN testAppendAndPrint() -> BOL = (
    list = List.INIT()
    first = Node.INIT()
    second = Node.INIT()
    third = Node.INIT()

    append(REF list, REF first, 1)
    append(REF list, REF second, 2)
    append(REF list, REF third, 3)

    printList(REF list)

    ret list.count == 3 && list.head.value == 1 && list.head.next.value == 2 && list.tail.value == 3
)

FN main() -> NUL = (
    assert(testAppendAndPrint(), "linked list append and print")
)
