    nums = [2, 4, 6]
    text = "Caster 123"
    scores = Scores.INIT()

    ret len(nums) == 3 && has(nums, 4) && find(nums, 6) == 2 && min(nums) == 2 && max(nums) == 6 && len(text) == 10 && has(text, "st") && find(text, "123") == 7 && len(scores) == 2 && has(scores, "math")
)

FN testCollectionMethodBody() -> BOL = (
    User user = testReturnContextRecordLiteral()
    totals = [user].upd(
        total = 0

        loop([e.tests])(
            total += e
        )

        total
    )

    ret totals.0 == 6
)

FN testStringSequenceAndMethods() -> BOL = (
    text = "a1b2c3"
    letters = text.filt(isAlpha(e))
    hiddenDigits = text.upd(
        if(isDigit(e))(
            "#"
        ) else (
            e
        )
    )
    rebuilt = text.agg( += e )
    lettersAgain = text.agg( += e if(isAlpha(e)) )

    seen = ""
    loop("Caster")(
        seen += e
    )

    ret text.0 == "a" && text.1 == "1" && letters == "abc" && hiddenDigits == "a#b#c#" && rebuilt == text && lettersAgain == "abc" && seen == "Caster"
)

FN testCollectionMethodBodyIfElse() -> BOL = (
    nums = [1, 2, 3, 4]

    updated = nums.upd(
        if(e % 2 == 0)(
            e * 10
        ) else (
            e
        )
    )

    filtered = nums.filt(
        if(e > 2)(
            true
        ) else (
            false
        )
    )

    total = nums.agg(
        += if(e > 2)(
            e
        )
    )

    ret updated.0 == 1 && updated.1 == 20 && updated.2 == 3 && updated.3 == 40 && filtered.len() == 2 && filtered.0 == 3 && filtered.1 == 4 && total == 7
)

FN testInPlaceArrayUpdFilt() -> BOL = (
    nums = [1, 2, 3, 4]

    *nums.upd(e * 2)
    *nums.filt(e > 4)

    ret nums.len() == 2 && nums.0 == 6 && nums.1 == 8
)

FN testInPlaceRefArrayUpdFilt() -> BOL = (
    nums = [1, 2, 3, 4]

    FN keepLarge(REF[ARR[INT]] items) -> NUL = (
        *items.upd(
            if(e < 3)(
                e + 10
            ) else(
                e
            )
        )

        *items.filt(
            if(e >= 4)(
                true
            ) else(
                false
            )
        )
    )

    keepLarge(REF nums)

    ret nums.len() == 3 && nums.0 == 11 && nums.1 == 12 && nums.2 == 4
)

