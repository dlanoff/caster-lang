    ret data
)

FN decodeScores(DYN data) -> Scores = (
    ret data
)

FN decodeMeasurement(DYN data) -> Measurement = (
    ret data
)

FN decodeProfile(DYN data) -> Profile = (
    ret data
)

FN testLocalPrimitiveInference() -> BOL = (
    count = 0
    name = "Ada"
    alive = true
    nums = [1, 2, 3]

    ret count == 0 && name == "Ada" && alive && nums.len() == 3
)

FN testNamedMapValueInference() -> BOL = (
    row = Row.INIT()
    scores = Scores.INIT()
    user = User.INIT()

    user = user.upd({
        name = "Ada"
    })

    scores = scores.upd({
        "math" = 9
    })

    ret row.len() == 0 && scores.math == 9 && user.name == "Ada" && user.age == 0
)

FN testNamedInitChain() -> BOL = (
    config = InitConfig.INIT()
        .upd({
            capacity = 32
        })

    ret config.capacity == 32 && config.label == "default"
)

FN testArrayAppendConcatRemove() -> BOL = (
    nums = []
    nums = nums.add(1)
    nums = nums.add([2, 3])
    nums -= 2

    ret nums.len() == 2 && nums.0 == 1 && nums.1 == 3
)

FN testNestedArrayDotAccess() -> BOL = (
    row = []
    *row.add(true)
    *row.add(false)

    grid = []
    *grid.add(row)
    *grid.add([false, true])

    r = 1
    c = 0

    ret grid.r.c == false && grid.[r].[c + 1] == true && grid.0.len() == 2
)

FN testBracketComputedDotLoopContext() -> BOL = (
    grid = [
        [1, 2],
        [3, 4]
    ]

    total = 0
    loop([grid] as rows)(
        total += grid.[rows.i].0
    )

    ret total == 4
)

FN testNestedLoopSourceFrame() -> BOL = (
    grid = [
        [true, false],
        [false, true]
    ]

    matches = 0
    weighted = 0

    loop([grid])(
        loop([e])(
            currentCell = e
            currentRow = grid.e
            rowIndex = grid.i
            colIndex = i

            if(currentCell == currentRow.[colIndex])(
                matches += 1
            )

            if(currentCell)(
                weighted += rowIndex * 10 + colIndex
            )
        )
    )

    ret matches == 4 && weighted == 11
)

FN testDynamicMapLiteralDotAndComputedDot() -> BOL = (
    scores = Scores.INIT()
    subject = "history"

    scores = scores.upd({
        [subject] = 4,
        "science" = 5
    })

    computed = scores.[subject + ""]

    ret scores.history == 4 && scores.subject == 4 && computed == 4 && scores.science == 5
)

FN testDynamicMapRuntimeJoinRemoveHas() -> BOL = (
    scores = Scores.INIT()
    scores = scores.upd({
        "art" = 3
    })

    before = scores.has("art")
    scores -= "art"

    ret before && !scores.has("art")
)

