FN testPromotedFixedMapLoop() -> BOL = (
    guest = Guest.INIT()
    guest = {guest} + {
        "nickname" = "Ada",
        "score" = 99
    }

    count = 0
    hasNickname = false
    hasScore = false

    loop({guest})(
        current = val
        count += 1

        if(e == "nickname")(
            hasNickname = true
        )

        if(e == "score")(
            hasScore = true
        )
    )

    ret count == 5 && hasNickname && hasScore
)

