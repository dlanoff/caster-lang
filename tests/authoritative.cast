FN testShapeFillComputedDimensions() -> BOL = (
    depth = 2 * 30 / 30
    grid = [2x3xdepth].fill(7)

    ret grid.len() == 2 && grid.0.len() == 3 && grid.[0].[0].len() == 2 && grid.[1].[2].[1] == 7
)

FN testShapeFillRandPerCell() -> BOL = (
    grid = [2x2].fill(RAND(1) * 100)

    allInRange = grid.agg(
        += .agg(
            += 1 if(e >= 0.0 && e < 100.0)
        )
    )
    different = grid.[0].[0] != grid.[0].[1] || grid.[0].[0] != grid.[1].[0] || grid.[0].[0] != grid.[1].[1]

    ret grid.len() == 2 && grid.0.len() == 2 && allInRange == 4 && different
)

FN testValueElseFallback() -> BOL = (
    emptyText = "" else "Guest"
    fullText = "Ada" else "Guest"
    zeroCount = 0 else 7
    realCount = 3 else 7
    zeroRatio = 0.0 else 1.5
    alive = false else true

    node = Node.INIT()
    chosenRef = node.next else REF node

    data = JSON(`{"name":"","age":0,"good":42,"nested":{"city":"Paris","zip":75000},"items":[0,5]}`)
    jsonName = data.name else "Guest"
    jsonAge = data.age else 99
    jsonGood = data.good else 99
    nestedName = data.nested.city else "Unknown"
    firstItem = data.items.0 else 8
    secondItem = data.items.1 else 8
    missingText = data.missing else "Missing"
    address = data.nested else Address
    fallbackAddress = data.missingAddress else Address

    ret emptyText == "Guest" && fullText == "Ada" && zeroCount == 7 && realCount == 3 && zeroRatio == 1.5 && alive && chosenRef == REF node && jsonName == "Guest" && jsonAge == 99 && jsonGood == 42 && nestedName == "Paris" && firstItem == 8 && secondItem == 5 && missingText == "Missing" && address.city == "Paris" && fallbackAddress.city == ""
)

FN testFunctionCall() -> BOL = (
    ret testCollectionSum()
)

FN testNestedFunctionRefMutation() -> BOL = (
    total = 1
    values = [1]

    FN add(REF[INT] total, REF[ARR[INT]] values, INT value) -> NUL = (
        *total = total + value
        *values.add(value)
    )

    add(REF total, REF values, 2)
    add(REF total, REF values, 3)

    ret total == 6 && values.len() == 3 && values.agg( += e ) == 6
)

FN firstCopyToken(REF[CopyTokenList] tokens) -> CopyToken = (
    ret tokens.0
)

FN readFirstAndDrop(REF[CopyTokenList] tokens) -> STR = (
    CopyToken token = firstCopyToken(tokens)
    ret token.text
)

FN mutateCopyBox(CopyBox box) -> STR = (
    box.words.0 = "changed"
    ret box.words.0
)

FN makeCopyBox() -> CopyBox = (
    ret {
        words = ["original"]
    }
)

FN testArrayElementValueCopy() -> BOL = (
    tokens = CopyTokenList.INIT()
    *tokens.add({
        kind = "NAME",
        text = "alpha"
    })

    STR firstText = readFirstAndDrop(REF tokens)
    tokenStillValid = tokens.0.kind == "NAME" && tokens.0.text == "alpha"

    CopyBox box = makeCopyBox()
    STR changedLocal = mutateCopyBox(box)

    ret firstText == "alpha" && tokenStillValid && changedLocal == "changed" && box.words.0 == "original"
)

