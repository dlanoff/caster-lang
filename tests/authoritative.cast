ARR[BOL] Row = []
ARR[Row] Grid = []

MAP[STR, INT] Scores = {
    "math" = 1,
    "science" = 2
}

ARR[FLT] Ratios = []

MAP[STR, STR] Complex = {}
MAP[STR, STR] Headers = {}

MAP HttpRes = {
    INT status = 0,
    STR body = "",
    Headers headers = INIT
}

MAP User = {
    STR name = "Guest",
    INT age = 0,
    ARR[INT] tests = [],
    Complex tags = INIT
}

MAP Guest = {
    STR name = "Guest",
    INT age = 0,
    Complex complex = INIT
}

MAP RefCounter = {
    INT value = 0
}

MAP InitConfig = {
    INT capacity = 8,
    STR label = "default"
}

MAP Node = {
    INT value = 0,
    REF[Node] next = NUL
}

MAP Measurement = {
    FLT temperature = 0.0,
    FLT count = 0.0
}

MAP Address = {
    STR city = "",
    INT zip = 0
}

MAP[STR, Address] AddressBook = {}

MAP Profile = {
    STR name = "",
    Address home = INIT,
    ARR[Address] stops = [],
    AddressBook contacts = INIT,
    ARR[INT] scores = [],
    REF[Node] next = NUL
}

MAP CopyToken = {
    STR kind = "",
    STR text = ""
}

ARR[CopyToken] CopyTokenList = []

MAP CopyBox = {
    ARR[STR] words = []
}

MAP Account = {
    INT id = 0,
    FLT balance = 0.0,
    BOL active = false,

    MAP owner = {
        STR name = "Guest",
        STR email = ""
    }
}

