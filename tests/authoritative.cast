FN testStringFunctions() -> BOL = (
    parts = "a,b,c".ARR(",")
    chars = "abc".ARR()
    joined = parts.STR()
    joinedWithDelimiter = parts.STR("|")

    ret trim("  Caster Lang  ") == "Caster Lang" && lower("Caster") == "caster" && upper("Caster") == "CASTER" && replace("hello world", "world", "Caster") == "hello Caster" && starts("main.cast", "main") && ends("main.cast", ".cast") && parts.len() == 3 && parts.0 == "a" && parts.1 == "b" && parts.2 == "c" && chars.len() == 3 && chars.0 == "a" && chars.2 == "c" && joined == "abc" && joinedWithDelimiter == "a|b|c" && isDigit("123") && !isDigit("12a") && isAlpha("Caster") && !isAlpha("Caster1") && isSpace("   ")
)

FN countChar(STR word, STR target) -> INT = (
    count = 0

    loop([word.ARR()])(
        if(e == target)(
            count += 1
        )
    )

    ret count
)

FN areAnagramsTwoPointer(STR left, STR right) -> BOL = (
    if(len(left) != len(right))(
        ret false
    )

    low = 0
    high = len(left) - 1

    loop(low <= high)(
        lowChar = left.low
        highChar = left.high

        if(countChar(left, lowChar) != countChar(right, lowChar))(
            ret false
        )

        if(low != high)(
            if(countChar(left, highChar) != countChar(right, highChar))(
                ret false
            )
        )

        low += 1
        high -= 1
    )

    ret true
)

FN testTwoPointerAnagrams() -> BOL = (
    ret areAnagramsTwoPointer("listen", "silent") && areAnagramsTwoPointer("evil", "vile") && !areAnagramsTwoPointer("cast", "cart") && !areAnagramsTwoPointer("abc", "abcc")
)

