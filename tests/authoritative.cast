    hasAlive = false

    loop({data})(
        current = val
        count += 1

        if(e == "name")(
            hasName = true
        )

        if(e == "age")(
            hasAge = true
        )

        if(e == "alive")(
            hasAlive = true
        )
    )

    ret count == 3 && hasName && hasAge && hasAlive
)

