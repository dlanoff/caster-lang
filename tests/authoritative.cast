FN testIsMixedDefaultAndExplicitCheck() -> BOL = (
    status = "Blocked"
    blockedStatus = "Blocked"
    blockedRejected = status IS "Bar" || != blockedStatus
    openStatus = "Open"
    openAllowed = openStatus IS "Bar" || != blockedStatus
    explicitOk = openStatus IS == "Bar" || == "Open"

    ret blockedRejected == false && openAllowed && explicitOk
)

FN testCollectionUpd() -> BOL = (
    nums = [1, 2]
    doubled = nums.upd(e * 2)

    ret doubled.0 == 2 && doubled.1 == 4
)

FN testCollectionFilt() -> BOL = (
    nums = [1, 2, 3, 4]
    kept = nums.filt(e > 2)

    ret kept.len() == 2 && kept.0 == 3 && kept.1 == 4
)

FN testCollectionSum() -> BOL = (
    nums = [1, 2, 3]

    ret nums.agg( += e ) == 6 && nums.agg( += e * 2 ) == 12 && nums.agg( += 1 if(e > 1) ) == 2
)

