assert(testNestedArrayDotAccess(), "nested array dot access")
assert(testBracketComputedDotLoopContext(), "bracket computed dot loop context")
assert(testNestedLoopSourceFrame(), "nested loop source frame")
assert(testDynamicMapLiteralDotAndComputedDot(), "dynamic map literal dot computed dot")
assert(testDynamicMapRuntimeJoinRemoveHas(), "dynamic map runtime join remove has")
assert(testMapLoop(), "map loop")
