FN bumpRefCounter(REF[RefCounter] counter) -> NUL = (
    *counter.value += 1
)

FN bumpInt(REF[INT] value) -> NUL = (
    *value = value + 1
)

FN replaceInt(REF[INT] value, INT next) -> NUL = (
    *value = next
)

FN testRefMutation() -> BOL = (
    counter = RefCounter.INIT()
    bumpRefCounter(REF counter)

    value = 1
    bumpInt(REF value)
    replaceInt(REF value, 9)

    bumpRefCounter(REF RefCounter)

    ret counter.value == 1 && value == 9 && RefCounter.value == 1
)

